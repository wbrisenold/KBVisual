  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js --host 0.0.0.0",
    "build": "node node_modules/vite/bin/vite.js build && node scripts/postbuild.mjs",
    "preview": "node node_modules/vite/bin/vite.js preview --host 0.0.0.0",
    "check": "node node_modules/typescript/bin/tsc --noEmit",
    "test:e2e": "node node_modules/@playwright/test/cli.js test",
    "validate:html": "node node_modules/html-validate/bin/html-validate.mjs \"dist/**/*.html\"",
    "unused": "node node_modules/knip/bin/knip.js --production",
    "verify": "npm run check && npm run build && npm run validate:html && npm run test:e2e",
    "analyze": "ANALYZE=true npm run build",
    "video:previews": "node scripts/youtube-playlist-previews.mjs"
  },
  "dependencies": {
